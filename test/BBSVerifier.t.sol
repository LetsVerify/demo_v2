pragma solidity ^0.8.20;

import "forge-std/Test.sol";
import "../src/BBSMath.sol";
import "../src/BBSVerifier.sol";

contract BBSVerifierTest is Test {
    BBSVerifier public verifier;
    
    bytes32 public constant CTX = bytes32("LetsVerify"); 

    function setUp() public {
        BBSMath.G2Point memory pk = BBSMath.G2Point({
            x: [
                3260306681974474822604563648776815682816091416970286175188033719997424721292,
                21078157932976788369811386224298604876283678095953300695193627580536184663017
            ],
            y: [
                15974835493233460998260511752626128505010865937675816409903067489306439600529,
                21872932232854780648641376857253831029627783545362812619304934661720191529610
            ]
        });

        BBSMath.G1Point[] memory bases = new BBSMath.G1Point[](6);
        bases[0] = BBSMath.G1Point(1240703902419481545648986623473745806820787811594483762868555478458184666010, 18256809644617940920254137422873442228473372063501986223346572230462785524439);
        bases[1] = BBSMath.G1Point(13020051060923754131228834502880722230806022247808159414293488215070332394772, 4529195280833079968741232889459250032235684423945803123503195484318934791269);
        bases[2] = BBSMath.G1Point(16297305326858617051978407466566022015897499588105011865519416711980789611480, 3457763090096090198366700259693644531770479248862060079356697617968728920669);
        bases[3] = BBSMath.G1Point(2253800715866524994843494300154676387161899760404330152495442103191129641090, 9799921154527725974487574934896288658143635125210110869057393462183450014056);
        bases[4] = BBSMath.G1Point(15591676955350207499762345130216057388364340524562767442403038585836757427173, 366693626097570863962860699973119751999356879228643136313636147692477681999);
        bases[5] = BBSMath.G1Point(21393812497764701958592826102470503271515498520329721604743009071119726253411, 16563212233814295780128168415970014578295470256244992910750946401593357383812);

        verifier = new BBSVerifier(
            pk, 
            bases
        );
    }

    function test_VerifyProof() public {
        // 4 consraints + m_null
        uint256[] memory messages = new uint256[](5);
        messages[0] = 4528752285148684012564256818462280771918828852546138746521208354411044252822;
        messages[1] = 8474321739458138899097646849860765932135651313862925479195387843221486033438;
        messages[2] = 1464662865008959075347130388737553683672515905673906344791000457739484483820;
        messages[3] = 1464662865008959075347130388737553683672515905673906344791000457739484483820;
        messages[4] = 192837465; // m_null

        // Load off-chain proof
        BBSVerifier.Proof memory proof = BBSVerifier.Proof({
            A_bar: BBSMath.G1Point(4179854549373647938910268115294581072706185687863174413170531162448041131203, 20210025142984011222056652656858926876353227415128028875057893584335833094561),
            B_bar: BBSMath.G1Point(1227402969657634430354195601747756016090133927089280083753025295027110736534, 8458497876411656801318655241350188994967206519721285737959024229403265170867),
            U: BBSMath.G1Point(17035810371453626241387371415567993318867865234729471761922831284708394104835, 99219156246168972039876991172570883884327041166160191052837059427977499355),
            s: 16018637230591439904573643880561864201630462128299484899669309922016419721602,
            t: 10582240665604962484703294327720900488520972873170677218820877890427331109089,
            u_gamma: 10372339021769194516104634340022921528470216438246179471902157948573761865541
        });

        // Verify the proof
        bool result = verifier.verifyProof(proof, messages, CTX);
        
        assertTrue(result, "Zero-Knowledge Proof verification failed!");
    }

    function test_VerifyProof_With_Offchain_Challenge() public {
        uint256[] memory messages = new uint256[](5);
        messages[0] = 4528752285148684012564256818462280771918828852546138746521208354411044252822;
        messages[1] = 8474321739458138899097646849860765932135651313862925479195387843221486033438;
        messages[2] = 1464662865008959075347130388737553683672515905673906344791000457739484483820;
        messages[3] = 1464662865008959075347130388737553683672515905673906344791000457739484483820;
        messages[4] = 192837465;

        BBSVerifier.Proof memory proof = BBSVerifier.Proof({
            A_bar: BBSMath.G1Point(4179854549373647938910268115294581072706185687863174413170531162448041131203, 20210025142984011222056652656858926876353227415128028875057893584335833094561),
            B_bar: BBSMath.G1Point(1227402969657634430354195601747756016090133927089280083753025295027110736534, 8458497876411656801318655241350188994967206519721285737959024229403265170867),
            U: BBSMath.G1Point(17035810371453626241387371415567993318867865234729471761922831284708394104835, 99219156246168972039876991172570883884327041166160191052837059427977499355),
            s: 16018637230591439904573643880561864201630462128299484899669309922016419721602,
            t: 10582240665604962484703294327720900488520972873170677218820877890427331109089,
            u_gamma: 10372339021769194516104634340022921528470216438246179471902157948573761865541
        });

        uint256 expectedChallenge = 5714904754124434343927539838299275324285299804229771027030388282527133126856;

        // 1. Pairing check: e(A_bar, PK) * e(-B_bar, G2) == 1
        bool pairingOk = BBSMath.pairing2(proof.A_bar, verifier.getPublicKey(), BBSMath.negate(proof.B_bar), verifier.getG2());
        assertTrue(pairingOk, "Pairing check failed");

        // 2. Homomorphic check
        // left = U + c*B_bar
        BBSMath.G1Point memory left = BBSMath.plus(proof.U, BBSMath.scalarMul(proof.B_bar, expectedChallenge));

        // compute C_J = G1 + sum(m_j * H_j)
        BBSMath.G1Point memory CJ = verifier.getG1();
        for (uint i = 0; i < messages.length; i++) {
            (uint256 px, uint256 py) = verifier.publicBases(i);
            CJ = BBSMath.plus(CJ, BBSMath.scalarMul(BBSMath.G1Point(px, py), messages[i]));
        }

        // right = s*C_J + t*A_bar + u_gamma*H_gamma
        BBSMath.G1Point memory right = BBSMath.scalarMul(CJ, proof.s);
        right = BBSMath.plus(right, BBSMath.scalarMul(proof.A_bar, proof.t));
        
        (uint256 gx, uint256 gy) = verifier.publicBases(5);
        BBSMath.G1Point memory hGamma = BBSMath.G1Point(gx, gy);
        right = BBSMath.plus(right, BBSMath.scalarMul(hGamma, proof.u_gamma));

        assertEq(left.x, right.x, "Homomorphic check failed: left.x != right.x");
        assertEq(left.y, right.y, "Homomorphic check failed: left.y != right.y");
    }
}